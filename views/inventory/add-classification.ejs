<main>
  <%- messages() %>
  <% if (typeof errors !== 'undefined' && errors && !errors.isEmpty()) { %>
    <div class="form-errors" role="alert">
      <ul>
        <% errors.array().forEach(function(err){ %>
          <li><%= err.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>
  <form id="add-classification-form" action="/inv/add-classification" method="POST" novalidate>
    <div>
      <label for="classification_name">Classification Name</label>
      <input
        type="text"
        id="classification_name"
        name="classification_name"
        required
        pattern="^[A-Za-z0-9]+$"
        maxlength="50"
        aria-describedby="classification_help validation_msg"
        value="<%= typeof classification_name !== 'undefined' ? classification_name : '' %>"
      />
      <p id="classification_help">Only letters and numbers. No spaces or special characters.</p>
      <p id="validation_msg" aria-live="polite"></p>
    </div>
    <button type="submit">Add Classification</button>
  </form>
</main>